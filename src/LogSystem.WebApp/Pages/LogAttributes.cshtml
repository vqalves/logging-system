@page "{logCollectionId:long?}"
@model LogSystem.WebApp.Pages.LogAttributesModel
@{
    ViewData["Title"] = "Log Attributes";
}

<nav class="breadcrumb-nav" aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/LogCollections">Log Collections</a></li>
        <li class="breadcrumb-item active" aria-current="page">Log Attributes</li>
    </ol>
</nav>

<div class="page-header-with-actions mb-4">
    <div class="page-header-content">
        <h1 class="page-title" id="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">Manage extraction attributes for log collection</p>
    </div>
    <div class="page-header-actions">
        <a href="/LogCollections" class="btn btn-outline-secondary">Back to Collections</a>
        <button id="create-button" class="btn btn-primary" style="display: none;">Create New Attribute</button>
    </div>
</div>

<div id="error-message" class="alert alert-danger alert-dismissible" role="alert" style="display: none;">
    <div class="alert-icon" role="img" aria-label="Error icon"></div>
    <div class="alert-content" id="error-message-text"></div>
    <button type="button" class="btn-close" aria-label="Close alert" onclick="document.getElementById('error-message').style.display='none'">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
<div id="success-message" class="alert alert-success alert-dismissible" role="alert" style="display: none;">
    <div class="alert-icon" role="img" aria-label="Success icon"></div>
    <div class="alert-content" id="success-message-text"></div>
    <button type="button" class="btn-close" aria-label="Close alert" onclick="document.getElementById('success-message').style.display='none'">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<div class="section">
    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover" id="attributes-table">
                <thead>
                    <tr>
                        <th class="col-id">ID</th>
                        <th class="col-expand">Name</th>
                        <th class="col-expand">SQL Column Name</th>
                        <th style="width: 140px;">Type</th>
                        <th style="width: 140px;">Extraction Style</th>
                        <th class="col-expand">Extraction Expression</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr id="loading-row" class="skeleton-row">
                        <td colspan="7"></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const logCollectionId = '@RouteData.Values["logCollectionId"]';
        let collectionName = '';

        document.addEventListener('DOMContentLoaded', function() {
            if (!logCollectionId || logCollectionId === '') {
                showError('LogCollectionId is required.');
                document.getElementById('loading-row').innerHTML = '<td colspan="7" class="text-center text-danger">LogCollectionId is required</td>';
                return;
            }

            loadLogCollection();
            loadAttributes();
        });

        async function loadLogCollection() {
            try {
                const response = await fetch('/api/log-collections');

                if (!response.ok) {
                    throw new Error(`Failed to load collections: ${response.statusText}`);
                }

                const collections = await response.json();
                const collection = collections.find(c => c.id == logCollectionId);

                if (!collection) {
                    showError('LogCollection not found.');
                    return;
                }

                collectionName = collection.name;
                document.getElementById('page-title').textContent = `Log Attributes - ${collectionName}`;

                // Show create button
                const createButton = document.getElementById('create-button');
                createButton.style.display = 'inline-block';
                createButton.onclick = () => window.location.href = `/LogAttributes/Manage?logCollectionId=${logCollectionId}`;

            } catch (error) {
                console.error('Error loading collection:', error);
                showError('Failed to load collection: ' + error.message);
            }
        }

        async function loadAttributes() {
            try {
                const response = await fetch(`/api/log-collections/${logCollectionId}/log-attributes`);

                if (!response.ok) {
                    throw new Error(`Failed to load attributes: ${response.statusText}`);
                }

                const attributes = await response.json();
                displayAttributes(attributes);
            } catch (error) {
                console.error('Error loading attributes:', error);
                showError('Failed to load attributes: ' + error.message);
                document.getElementById('loading-row').innerHTML = '<td colspan="7" class="text-center text-danger">Failed to load attributes</td>';
            }
        }

        function displayAttributes(attributes) {
            const tbody = document.querySelector('#attributes-table tbody');

            if (attributes.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="table-empty">
                            <div class="table-empty-message">No attributes defined</div>
                            <div class="table-empty-description">Create your first log attribute to start extracting data from logs</div>
                            <div class="mt-3">
                                <button class="btn btn-primary btn-lg" onclick="window.location.href='/LogAttributes/Manage?logCollectionId=${logCollectionId}'">Create First Attribute</button>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            tbody.innerHTML = '';

            attributes.forEach(attribute => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="col-id">${attribute.id}</td>
                    <td>${escapeHtml(attribute.name)}</td>
                    <td><code class="text-primary">${escapeHtml(attribute.sqlColumnName)}</code></td>
                    <td><span class="badge bg-info">${escapeHtml(attribute.attributeTypeID)}</span></td>
                    <td><span class="badge bg-secondary">${escapeHtml(attribute.extractionStyleID)}</span></td>
                    <td class="col-truncate" title="${escapeHtml(attribute.extractionExpression)}"><code>${escapeHtml(attribute.extractionExpression)}</code></td>
                    <td class="col-actions">
                        <div class="btn-group-table">
                            <a href="/LogAttributes/Edit/${attribute.id}" class="btn btn-sm btn-primary" title="Edit attribute">Edit</a>
                            <button class="btn btn-sm btn-danger" onclick="deleteAttribute(${attribute.id}, '${escapeHtml(attribute.name)}')" title="Delete attribute">Delete</button>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        async function deleteAttribute(id, name) {
            if (!confirm(`Are you sure you want to delete the attribute "${name}"? This will also drop the associated column and all data.`)) {
                return;
            }

            try {
                const response = await fetch(`/api/log-attributes/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showSuccess(`Attribute "${name}" deleted successfully.`);
                    loadAttributes(); // Reload the table
                } else if (response.status === 404) {
                    showError('Attribute not found.');
                } else {
                    const error = await response.json();
                    showError('Failed to delete attribute: ' + (error.detail || response.statusText));
                }
            } catch (error) {
                console.error('Error deleting attribute:', error);
                showError('Failed to delete attribute: ' + error.message);
            }
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            const errorText = document.getElementById('error-message-text');
            errorText.textContent = message;
            errorDiv.style.display = 'flex';

            // Hide success message
            document.getElementById('success-message').style.display = 'none';

            // Manual dismiss only for errors (no auto-hide)
        }

        function showSuccess(message) {
            const successDiv = document.getElementById('success-message');
            const successText = document.getElementById('success-message-text');
            successText.textContent = message;
            successDiv.style.display = 'flex';

            // Hide error message
            document.getElementById('error-message').style.display = 'none';

            // Auto-hide after 3 seconds (success messages)
            setTimeout(() => {
                dismissAlert(successDiv);
            }, 3000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
}
