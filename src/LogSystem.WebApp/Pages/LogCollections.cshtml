@page
@model LogSystem.WebApp.Pages.LogCollectionsModel
@{
    ViewData["Title"] = "Log Collections";
}

<nav class="breadcrumb-nav" aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Log Collections</li>
    </ol>
</nav>

<div class="page-header-with-actions mb-4">
    <div class="page-header-content">
        <h1 class="page-title">Log Collections</h1>
        <p class="page-subtitle">Manage log collections and monitor collection metrics</p>
    </div>
    <div class="page-header-actions">
        <a href="/LogCollections/Manage" class="btn btn-primary">Create New Collection</a>
    </div>
</div>

<div id="error-message" class="alert alert-danger alert-dismissible" role="alert" style="display: none;">
    <div class="alert-icon" role="img" aria-label="Error icon"></div>
    <div class="alert-content" id="error-message-text"></div>
    <button type="button" class="btn-close" aria-label="Close alert" onclick="document.getElementById('error-message').style.display='none'">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
<div id="success-message" class="alert alert-success alert-dismissible" role="alert" style="display: none;">
    <div class="alert-icon" role="img" aria-label="Success icon"></div>
    <div class="alert-content" id="success-message-text"></div>
    <button type="button" class="btn-close" aria-label="Close alert" onclick="document.getElementById('success-message').style.display='none'">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<div class="section">
    <div class="section-header">
        <h2 class="section-title">Collections Overview</h2>
        <p class="section-subtitle">View and manage all log collections with real-time metrics</p>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover" id="collections-table">
                <thead>
                    <tr>
                        <th colspan="7" class="table-secondary text-center py-2">
                            <small class="text-muted">Real-time Metrics (60s window)</small>
                        </th>
                    </tr>
                    <tr>
                        <th class="col-id">ID</th>
                        <th class="col-expand">Name</th>
                        <th class="col-expand">Table Name</th>
                        <th class="col-numeric" style="width: 140px;">Duration (Days)</th>
                        <th class="col-numeric" style="width: 120px;">Avg Msg/sec</th>
                        <th class="col-numeric" style="width: 100px;">Failed</th>
                        <th class="col-actions-lg">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr id="loading-row" class="skeleton-row">
                        <td colspan="7"></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let metricsPollingTimeout = null;
        let isPollingActive = true;

        // Load collections on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadCollections();
            startMetricsPolling();
        });

        async function loadCollections() {
            try {
                const response = await fetch('/api/log-collections');

                if (!response.ok) {
                    throw new Error(`Failed to load collections: ${response.statusText}`);
                }

                const collections = await response.json();
                displayCollections(collections);
            } catch (error) {
                console.error('Error loading collections:', error);
                showError('Failed to load collections: ' + error.message);
                document.getElementById('loading-row').innerHTML = '<td colspan="7" class="text-center text-danger">Failed to load collections</td>';
            }
        }

        function displayCollections(collections) {
            const tbody = document.querySelector('#collections-table tbody');

            if (collections.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="table-empty">
                            <div class="table-empty-message">No collections found</div>
                            <div class="table-empty-description">Get started by creating your first log collection</div>
                            <div class="mt-3">
                                <a href="/LogCollections/Manage" class="btn btn-primary btn-lg">Create New Collection</a>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            tbody.innerHTML = '';

            collections.forEach(collection => {
                const row = document.createElement('tr');
                row.setAttribute('data-client-id', collection.clientId);
                row.innerHTML = `
                    <td class="col-id">${collection.id}</td>
                    <td>${escapeHtml(collection.name)}</td>
                    <td>${escapeHtml(collection.tableName)}</td>
                    <td class="col-numeric">${collection.logDurationDays}</td>
                    <td class="col-numeric metric-avg-msg-sec" data-client-id="${escapeHtml(collection.clientId)}">-</td>
                    <td class="col-numeric metric-failed-count" data-client-id="${escapeHtml(collection.clientId)}">-</td>
                    <td class="col-actions-lg">
                        <div class="btn-group-table">
                            <a href="/LogCollections/Manage/${collection.id}" class="btn btn-sm btn-primary" title="Edit collection">Edit</a>
                            <a href="/LogAttributes/${collection.id}" class="btn btn-sm btn-secondary" title="Manage attributes">Attributes</a>
                            <a href="/SearchLogs?LogCollectionId=${collection.id}" class="btn btn-sm btn-success" title="Search logs">Search</a>
                            <button class="btn btn-sm btn-danger" onclick="deleteCollection(${collection.id}, '${escapeHtml(collection.name)}')" title="Delete collection">Delete</button>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        async function deleteCollection(id, name) {
            if (!confirm(`Are you sure you want to delete the collection "${name}"? This will also drop the associated table and all data.`)) {
                return;
            }

            try {
                const response = await fetch(`/api/log-collections/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showSuccess(`Collection "${name}" deleted successfully.`);
                    loadCollections(); // Reload the table
                } else if (response.status === 404) {
                    showError('Collection not found.');
                } else {
                    const error = await response.json();
                    showError('Failed to delete collection: ' + (error.detail || response.statusText));
                }
            } catch (error) {
                console.error('Error deleting collection:', error);
                showError('Failed to delete collection: ' + error.message);
            }
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            const errorText = document.getElementById('error-message-text');
            errorText.textContent = message;
            errorDiv.style.display = 'flex';

            // Hide success message
            document.getElementById('success-message').style.display = 'none';

            // Manual dismiss only for errors (no auto-hide)
        }

        function showSuccess(message) {
            const successDiv = document.getElementById('success-message');
            const successText = document.getElementById('success-message-text');
            successText.textContent = message;
            successDiv.style.display = 'flex';

            // Hide error message
            document.getElementById('error-message').style.display = 'none';

            // Auto-hide after 3 seconds (success messages)
            setTimeout(() => {
                dismissAlert(successDiv);
            }, 3000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function startMetricsPolling() {
            isPollingActive = true;
            loadMetrics();
        }

        async function loadMetrics() {
            if (!isPollingActive) {
                return;
            }

            try {
                const response = await fetch('/api/log-collections/metrics');

                if (!response.ok) {
                    console.error('Failed to load metrics:', response.statusText);
                    return;
                }

                const metrics = await response.json();
                updateMetricsDisplay(metrics);
            } catch (error) {
                console.error('Error loading metrics:', error);
            } finally {
                // Schedule next poll only after current request completes
                if (isPollingActive) {
                    metricsPollingTimeout = setTimeout(loadMetrics, 5000);
                }
            }
        }

        function updateMetricsDisplay(metrics) {
            // Create a map of clientId to metrics for quick lookup
            const metricsMap = new Map();
            metrics.forEach(metric => {
                metricsMap.set(metric.collectionClientId, metric);
            });

            // Update all metric cells
            document.querySelectorAll('.metric-avg-msg-sec').forEach(cell => {
                const clientId = cell.getAttribute('data-client-id');
                const metric = metricsMap.get(clientId);
                const oldValue = cell.textContent;

                if (metric) {
                    const newValue = metric.averageMessagesPerSecond.toFixed(2);

                    // Add pulse animation if value changed
                    if (oldValue !== '-' && oldValue !== newValue) {
                        cell.classList.add('metric-updated');
                        setTimeout(() => cell.classList.remove('metric-updated'), 300);
                    }

                    cell.textContent = newValue;

                    // Add visual indicator for active processing
                    if (metric.averageMessagesPerSecond > 0) {
                        cell.classList.add('text-success', 'fw-bold');
                    } else {
                        cell.classList.remove('text-success', 'fw-bold');
                    }
                } else {
                    cell.textContent = '0.00';
                    cell.classList.remove('text-success', 'fw-bold');
                }
            });

            document.querySelectorAll('.metric-failed-count').forEach(cell => {
                const clientId = cell.getAttribute('data-client-id');
                const metric = metricsMap.get(clientId);
                const oldValue = cell.textContent;

                if (metric) {
                    const newValue = String(metric.failedCount);

                    // Add pulse animation if value changed
                    if (oldValue !== '-' && oldValue !== newValue) {
                        cell.classList.add('metric-updated');
                        setTimeout(() => cell.classList.remove('metric-updated'), 300);
                    }

                    cell.textContent = newValue;

                    // Add visual indicator for failures
                    if (metric.failedCount > 0) {
                        cell.classList.add('text-danger', 'fw-bold');
                    } else {
                        cell.classList.remove('text-danger', 'fw-bold');
                    }
                } else {
                    cell.textContent = '0';
                    cell.classList.remove('text-danger', 'fw-bold');
                }
            });
        }

        // Stop polling when page is unloaded to prevent memory leaks
        window.addEventListener('beforeunload', function() {
            isPollingActive = false;
            if (metricsPollingTimeout) {
                clearTimeout(metricsPollingTimeout);
            }
        });
    </script>
}
