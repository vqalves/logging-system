@page
@model LogSystem.WebApp.Pages.LogCollectionsModel
@{
    ViewData["Title"] = "Log Collections";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <a href="/LogCollections/Manage" class="btn btn-primary">Create New Collection</a>
</div>

<div id="error-message" class="alert alert-danger" style="display: none;"></div>
<div id="success-message" class="alert alert-success" style="display: none;"></div>

<table class="table table-striped" id="collections-table">
    <thead>
        <tr>
            <th></th>
            <th></th>
            <th></th>
            <th></th>
            <th colspan="2" style="background-color:#ccc">(10s window)</th>
            <th></th>
        </tr>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Table Name</th>
            <th>Log Duration (Days)</th>
            <th style="background-color:#ccc">Avg Msg/sec</th>
            <th style="background-color:#ccc">Failed</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <tr id="loading-row">
            <td colspan="7" class="text-center">Loading...</td>
        </tr>
    </tbody>
</table>

@section Scripts {
    <script>
        let metricsPollingTimeout = null;
        let isPollingActive = true;

        // Load collections on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadCollections();
            startMetricsPolling();
        });

        async function loadCollections() {
            try {
                const response = await fetch('/api/log-collections');

                if (!response.ok) {
                    throw new Error(`Failed to load collections: ${response.statusText}`);
                }

                const collections = await response.json();
                displayCollections(collections);
            } catch (error) {
                console.error('Error loading collections:', error);
                showError('Failed to load collections: ' + error.message);
                document.getElementById('loading-row').innerHTML = '<td colspan="7" class="text-center text-danger">Failed to load collections</td>';
            }
        }

        function displayCollections(collections) {
            const tbody = document.querySelector('#collections-table tbody');

            if (collections.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center">No collections found</td></tr>';
                return;
            }

            tbody.innerHTML = '';

            collections.forEach(collection => {
                const row = document.createElement('tr');
                row.setAttribute('data-client-id', collection.clientId);
                row.innerHTML = `
                    <td>${collection.id}</td>
                    <td>${escapeHtml(collection.name)}</td>
                    <td>${escapeHtml(collection.tableName)}</td>
                    <td>${collection.logDurationDays}</td>
                    <td class="metric-avg-msg-sec" data-client-id="${escapeHtml(collection.clientId)}">-</td>
                    <td class="metric-failed-count" data-client-id="${escapeHtml(collection.clientId)}">-</td>
                    <td>
                        <a href="/LogCollections/Manage/${collection.id}" class="btn btn-sm btn-primary">Edit</a>
                        <a href="/LogAttributes/${collection.id}" class="btn btn-sm btn-info">Attributes</a>
                        <a href="/SearchLogs?LogCollectionId=${collection.id}" class="btn btn-sm btn-success">Search Logs</a>
                        <button class="btn btn-sm btn-danger" onclick="deleteCollection(${collection.id}, '${escapeHtml(collection.name)}')">Delete</button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        async function deleteCollection(id, name) {
            if (!confirm(`Are you sure you want to delete the collection "${name}"? This will also drop the associated table and all data.`)) {
                return;
            }

            try {
                const response = await fetch(`/api/log-collections/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showSuccess(`Collection "${name}" deleted successfully.`);
                    loadCollections(); // Reload the table
                } else if (response.status === 404) {
                    showError('Collection not found.');
                } else {
                    const error = await response.json();
                    showError('Failed to delete collection: ' + (error.detail || response.statusText));
                }
            } catch (error) {
                console.error('Error deleting collection:', error);
                showError('Failed to delete collection: ' + error.message);
            }
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';

            // Hide success message
            document.getElementById('success-message').style.display = 'none';

            // Auto-hide after 5 seconds
            setTimeout(() => {
                errorDiv.style.display = 'none';
            }, 5000);
        }

        function showSuccess(message) {
            const successDiv = document.getElementById('success-message');
            successDiv.textContent = message;
            successDiv.style.display = 'block';

            // Hide error message
            document.getElementById('error-message').style.display = 'none';

            // Auto-hide after 3 seconds
            setTimeout(() => {
                successDiv.style.display = 'none';
            }, 3000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function startMetricsPolling() {
            isPollingActive = true;
            loadMetrics();
        }

        async function loadMetrics() {
            if (!isPollingActive) {
                return;
            }

            try {
                const response = await fetch('/api/log-collections/metrics');

                if (!response.ok) {
                    console.error('Failed to load metrics:', response.statusText);
                    return;
                }

                const metrics = await response.json();
                updateMetricsDisplay(metrics);
            } catch (error) {
                console.error('Error loading metrics:', error);
            } finally {
                // Schedule next poll only after current request completes
                if (isPollingActive) {
                    metricsPollingTimeout = setTimeout(loadMetrics, 5000);
                }
            }
        }

        function updateMetricsDisplay(metrics) {
            // Create a map of clientId to metrics for quick lookup
            const metricsMap = new Map();
            metrics.forEach(metric => {
                metricsMap.set(metric.collectionClientId, metric);
            });

            // Update all metric cells
            document.querySelectorAll('.metric-avg-msg-sec').forEach(cell => {
                const clientId = cell.getAttribute('data-client-id');
                const metric = metricsMap.get(clientId);

                if (metric) {
                    cell.textContent = metric.averageMessagesPerSecond.toFixed(2);

                    // Add visual indicator for active processing
                    if (metric.averageMessagesPerSecond > 0) {
                        cell.classList.add('text-success', 'fw-bold');
                    } else {
                        cell.classList.remove('text-success', 'fw-bold');
                    }
                } else {
                    cell.textContent = '0.00';
                    cell.classList.remove('text-success', 'fw-bold');
                }
            });

            document.querySelectorAll('.metric-failed-count').forEach(cell => {
                const clientId = cell.getAttribute('data-client-id');
                const metric = metricsMap.get(clientId);

                if (metric) {
                    cell.textContent = metric.failedCount;

                    // Add visual indicator for failures
                    if (metric.failedCount > 0) {
                        cell.classList.add('text-danger', 'fw-bold');
                    } else {
                        cell.classList.remove('text-danger', 'fw-bold');
                    }
                } else {
                    cell.textContent = '0';
                    cell.classList.remove('text-danger', 'fw-bold');
                }
            });
        }

        // Stop polling when page is unloaded to prevent memory leaks
        window.addEventListener('beforeunload', function() {
            isPollingActive = false;
            if (metricsPollingTimeout) {
                clearTimeout(metricsPollingTimeout);
            }
        });
    </script>
}
