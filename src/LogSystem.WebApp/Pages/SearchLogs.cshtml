@page
@model LogSystem.WebApp.Pages.SearchLogsModel
@{
    ViewData["Title"] = "Search Logs";
}

<nav class="breadcrumb-nav" aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/LogCollections">Log Collections</a></li>
        <li class="breadcrumb-item active" aria-current="page">Search Logs</li>
    </ol>
</nav>

<div class="page-title-wrapper">
    <h1 class="page-title">Search Logs</h1>
    <p id="collection-name" class="page-subtitle">Loading collection information...</p>
</div>

<div id="error-message" class="alert alert-danger alert-dismissible" role="alert" style="display: none;">
    <div class="alert-icon" role="img" aria-label="Error icon"></div>
    <div class="alert-content" id="error-message-text"></div>
    <button type="button" class="btn-close" aria-label="Close alert" onclick="document.getElementById('error-message').style.display='none'">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
<div id="success-message" class="alert alert-success alert-dismissible" role="alert" style="display: none;">
    <div class="alert-icon" role="img" aria-label="Success icon"></div>
    <div class="alert-content" id="success-message-text"></div>
    <button type="button" class="btn-close" aria-label="Close alert" onclick="document.getElementById('success-message').style.display='none'">
        <span aria-hidden="true">&times;</span>
    </button>
</div>

<!-- Filters Section -->
<section class="section">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Search Filters</h2>
            <button id="toggle-filters-btn" class="btn btn-sm btn-outline-secondary d-md-none" aria-expanded="true" aria-controls="filters-body">
                <span id="toggle-filters-icon">−</span> <span class="visually-hidden">Toggle filters</span>
            </button>
        </div>
        <div class="card-body" id="filters-body">
            <!-- Active Filters Summary (Pills) -->
            <div id="active-filters-summary" class="mb-3" style="display: none;">
                <div class="d-flex align-items-center mb-2">
                    <strong class="text-muted" style="font-size: 0.875rem;">Active Filters:</strong>
                    <button id="clear-all-pills-btn" class="btn btn-sm btn-link text-danger ms-2 p-0" style="font-size: 0.875rem; text-decoration: none;">
                        Clear All
                    </button>
                </div>
                <div id="filter-pills-container" class="d-flex flex-wrap gap-2"></div>
            </div>

            <!-- Filter Builder -->
            <div id="filters-container">
                <p class="text-muted">Loading attributes...</p>
            </div>

            <!-- Action Buttons -->
            <div class="mt-4 d-flex flex-wrap gap-3 align-items-center">
                <button id="add-filter-btn" class="btn btn-icon btn-secondary" style="display: none;" aria-label="Add filter">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                    </svg>
                    <span>Add Filter</span>
                </button>
                <button id="search-btn" class="btn btn-primary" style="display: none;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <span>Search</span>
                </button>
                <button id="clear-filters-btn" class="btn btn-outline-secondary" style="display: none;">Clear Filters</button>
            </div>
        </div>
    </div>

<!-- Results Section -->
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <h2 class="h5 mb-0">Search Results</h2>
                    <span id="results-count" class="badge bg-primary" style="display: none; font-size: 0.875rem; padding: 0.5rem 0.75rem;">0 records</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button id="column-toggle-btn" class="btn btn-sm btn-outline-secondary" style="display: none;" aria-label="Toggle columns">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                            <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm5 10v-2a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1zm0-5V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1z"/>
                        </svg>
                        <span class="d-none d-sm-inline">Columns</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div id="results-container">
                <div class="table-empty">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="table-empty-icon" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <div class="table-empty-message">No search performed yet</div>
                    <div class="table-empty-description">
                        <p class="mb-2">Apply filters above and click Search to view log records</p>
                        <small class="text-muted">
                            <strong>Tips:</strong> Use filters to narrow down your search. You can combine multiple filters for more specific results.
                        </small>
                    </div>
                </div>
            </div>
        </div>
        <div id="load-more-container" class="card-footer text-center" style="display: none;">
            <button id="load-more-btn" class="btn btn-outline-primary btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path fill-rule="evenodd" d="M1 8a7 7 0 1 0 14 0A7 7 0 0 0 1 8zm15 0A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8.5 4.5a.5.5 0 0 0-1 0v5.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V4.5z"/>
                </svg>
                <span>Load More Results</span>
            </button>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        let logCollectionId = @Model.LogCollectionId;
        let attributes = [];
        let filters = [];
        let logs = [];
        let nextLastId = null;
        let isLoading = false;
        let visibleColumns = {}; // Track column visibility

        // DateTime mask function for dd/MM/yyyy HH:mm format
        function applyDateTimeMask(input) {
            input.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, ''); // Remove non-digits
                let formatted = '';

                // Format as dd/MM/yyyy HH:mm
                if (value.length > 0) {
                    formatted = value.substring(0, 2); // dd
                }
                if (value.length >= 3) {
                    formatted += '/' + value.substring(2, 4); // MM
                }
                if (value.length >= 5) {
                    formatted += '/' + value.substring(4, 8); // yyyy
                }
                if (value.length >= 9) {
                    formatted += ' ' + value.substring(8, 10); // HH
                }
                if (value.length >= 11) {
                    formatted += ':' + value.substring(10, 12); // mm
                }

                e.target.value = formatted;
            });

            input.addEventListener('keydown', function(e) {
                // Allow: backspace, delete, tab, escape, enter
                if ([46, 8, 9, 27, 13].indexOf(e.keyCode) !== -1 ||
                    // Allow: Ctrl+A, Ctrl+C, Ctrl+V, Ctrl+X
                    (e.keyCode === 65 && e.ctrlKey === true) ||
                    (e.keyCode === 67 && e.ctrlKey === true) ||
                    (e.keyCode === 86 && e.ctrlKey === true) ||
                    (e.keyCode === 88 && e.ctrlKey === true) ||
                    // Allow: home, end, left, right
                    (e.keyCode >= 35 && e.keyCode <= 39)) {
                    return;
                }
                // Ensure that it is a number and stop the keypress
                if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {
                    e.preventDefault();
                }
                // Limit to 16 characters (dd/MM/yyyy HH:mm)
                if (e.target.value.replace(/\D/g, '').length >= 12) {
                    e.preventDefault();
                }
            });
        }

        // Convert dd/MM/yyyy HH:mm to ISO format (UTC)
        function dateTimeToISO(dateTimeStr) {
            if (!dateTimeStr || dateTimeStr.trim() === '') return null;

            const match = dateTimeStr.match(/^(\d{2})\/(\d{2})\/(\d{4})\s(\d{2}):(\d{2})$/);
            if (!match) return null;

            const [, day, month, year, hour, minute] = match;

            // Create ISO format: yyyy-MM-ddTHH:mm:ss
            return `${year}-${month}-${day}T${hour}:${minute}:00`;
        }

        // Format ISO datetime to dd/MM/yyyy HH:mm
        function formatDateTime(isoString) {
            if (!isoString) return '';

            const date = new Date(isoString);
            if (isNaN(date.getTime())) return isoString;

            const day = String(date.getUTCDate()).padStart(2, '0');
            const month = String(date.getUTCMonth() + 1).padStart(2, '0');
            const year = date.getUTCFullYear();
            const hours = String(date.getUTCHours()).padStart(2, '0');
            const minutes = String(date.getUTCMinutes()).padStart(2, '0');

            return `${day}/${month}/${year} ${hours}:${minutes}`;
        }

        const operatorsByType = {
            'text': [
                { value: '=', name: 'Equal', symbol: '=' },
                { value: '!=', name: 'Not Equal', symbol: '≠' },
                { value: 'CONTAINS', name: 'Contains', symbol: '⊃' },
                { value: 'STARTSWITH', name: 'Starts With', symbol: 'A*' },
                { value: 'ENDSWITH', name: 'Ends With', symbol: '*Z' },
                { value: 'ISNULL', name: 'Is Null', symbol: '∅' },
                { value: 'ISNOTNULL', name: 'Is Not Null', symbol: '∄' }
            ],
            'integer': [
                { value: '=', name: 'Equal', symbol: '=' },
                { value: '!=', name: 'Not Equal', symbol: '≠' },
                { value: '<', name: 'Less Than', symbol: '<' },
                { value: '<=', name: 'Less Than or Equal', symbol: '≤' },
                { value: '>', name: 'Greater Than', symbol: '>' },
                { value: '>=', name: 'Greater Than or Equal', symbol: '≥' },
                { value: 'ISNULL', name: 'Is Null', symbol: '∅' },
                { value: 'ISNOTNULL', name: 'Is Not Null', symbol: '∄' }
            ],
            'decimal': [
                { value: '=', name: 'Equal', symbol: '=' },
                { value: '!=', name: 'Not Equal', symbol: '≠' },
                { value: '<', name: 'Less Than', symbol: '<' },
                { value: '<=', name: 'Less Than or Equal', symbol: '≤' },
                { value: '>', name: 'Greater Than', symbol: '>' },
                { value: '>=', name: 'Greater Than or Equal', symbol: '≥' },
                { value: 'ISNULL', name: 'Is Null', symbol: '∅' },
                { value: 'ISNOTNULL', name: 'Is Not Null', symbol: '∄' }
            ],
            'datetime': [
                { value: '=', name: 'Equal', symbol: '=' },
                { value: '!=', name: 'Not Equal', symbol: '≠' },
                { value: '<', name: 'Before', symbol: '<' },
                { value: '<=', name: 'Before or Equal', symbol: '≤' },
                { value: '>', name: 'After', symbol: '>' },
                { value: '>=', name: 'After or Equal', symbol: '≥' },
                { value: 'ISNULL', name: 'Is Null', symbol: '∅' },
                { value: 'ISNOTNULL', name: 'Is Not Null', symbol: '∄' }
            ],
            'boolean': [
                { value: '=', name: 'Equal', symbol: '=' },
                { value: 'ISNULL', name: 'Is Null', symbol: '∅' },
                { value: 'ISNOTNULL', name: 'Is Not Null', symbol: '∄' }
            ]
        };

        document.addEventListener('DOMContentLoaded', function() {
            loadCollectionInfo();
        });

        async function loadCollectionInfo() {
            try {
                const response = await fetch(`/api/log-collections/${logCollectionId}/log-attributes`);

                if (!response.ok) {
                    throw new Error(`Failed to load collection: ${response.statusText}`);
                }

                const attributesData = await response.json();
                attributes = attributesData;

                // Update collection name (fetch from collections endpoint)
                const collectionResponse = await fetch('/api/log-collections');
                if (collectionResponse.ok) {
                    const collections = await collectionResponse.json();
                    const collection = collections.find(c => c.id === logCollectionId);
                    if (collection) {
                        document.getElementById('collection-name').textContent = `Collection: ${escapeHtml(collection.name)} (${escapeHtml(collection.tableName)})`;
                    }
                }

                renderFilters();
                document.getElementById('add-filter-btn').style.display = 'inline-block';
                document.getElementById('search-btn').style.display = 'inline-block';
                document.getElementById('clear-filters-btn').style.display = 'inline-block';

            } catch (error) {
                console.error('Error loading collection:', error);
                showError('Failed to load collection: ' + error.message);
            }
        }

        function updateFilterAttribute(index, newAttributeId) {
            filters[index].attributeId = newAttributeId;
            // Reset operator and value when attribute changes
            const selectedAttr = attributes.find(a => a.id == newAttributeId);
            const operators = operatorsByType[selectedAttr.attributeTypeID] || operatorsByType['text'];
            filters[index].operator = operators[0].value;
            filters[index].value = '';
            renderFilters();
        }

        function updateFilterOperator(index, newOperator) {
            filters[index].operator = newOperator;
            // Clear value for null operators
            if (newOperator === 'ISNULL' || newOperator === 'ISNOTNULL') {
                filters[index].value = '';
            }
            renderFilters();
        }

        function updateFilterValue(index, newValue) {
            filters[index].value = newValue;
            // No render needed - just update the array
        }

        function renderFilterPills() {
            const summaryContainer = document.getElementById('active-filters-summary');
            const pillsContainer = document.getElementById('filter-pills-container');

            if (filters.length === 0) {
                summaryContainer.style.display = 'none';
                return;
            }

            summaryContainer.style.display = 'block';
            let pillsHtml = '';

            filters.forEach((filter, index) => {
                const selectedAttr = attributes.find(a => a.id == filter.attributeId);
                const operators = operatorsByType[selectedAttr.attributeTypeID] || operatorsByType['text'];
                const operatorObj = operators.find(op => op.value === filter.operator);
                const operatorSymbol = operatorObj ? operatorObj.symbol : filter.operator;

                let displayValue = filter.value;
                if (filter.operator === 'ISNULL' || filter.operator === 'ISNOTNULL') {
                    displayValue = '';
                } else if (selectedAttr.attributeTypeID === 'datetime' && filter.value) {
                    displayValue = filter.value; // Already formatted
                }

                const pillText = displayValue
                    ? `${escapeHtml(selectedAttr.name)} ${operatorSymbol} ${escapeHtml(displayValue)}`
                    : `${escapeHtml(selectedAttr.name)} ${operatorSymbol}`;

                pillsHtml += `
                    <span class="badge bg-secondary d-inline-flex align-items-center gap-2" style="font-size: 0.875rem; padding: 0.5rem 0.75rem;">
                        <span>${pillText}</span>
                        <button type="button" class="btn-close btn-close-white" style="font-size: 0.625rem; padding: 0; width: 0.75rem; height: 0.75rem;"
                                onclick="removeFilter(${index})" aria-label="Remove filter for ${escapeHtml(selectedAttr.name)}"></button>
                    </span>`;
            });

            pillsContainer.innerHTML = pillsHtml;
        }

        function renderFilters() {
            const container = document.getElementById('filters-container');

            if (attributes.length === 0) {
                container.innerHTML = '<p class="text-muted">No attributes defined for this collection. Please add attributes first.</p>';
                return;
            }

            if (filters.length === 0) {
                container.innerHTML = '<p class="text-muted">No filters applied. Click "Add Filter" to add one.</p>';
                renderFilterPills();
                return;
            }

            // Render filter pills first
            renderFilterPills();

            // Create card-based filter builder
            let filtersHtml = '<div class="row g-3">';

            filters.forEach((filter, index) => {
                const selectedAttr = attributes.find(a => a.id == filter.attributeId);
                const operators = operatorsByType[selectedAttr.attributeTypeID] || operatorsByType['text'];

                // Determine input type and properties based on attribute type
                let inputType = 'text';
                let inputStep = '';
                let inputDisabled = false;
                let inputValue = filter.value || '';
                let inputPlaceholder = 'Enter value';

                if (selectedAttr.attributeTypeID === 'datetime') {
                    inputType = 'text';
                    inputPlaceholder = 'dd/MM/yyyy HH:mm';
                } else if (selectedAttr.attributeTypeID === 'integer') {
                    inputType = 'number';
                } else if (selectedAttr.attributeTypeID === 'decimal') {
                    inputType = 'number';
                    inputStep = '0.0001';
                }

                // Disable value input for null operators
                if (filter.operator === 'ISNULL' || filter.operator === 'ISNOTNULL') {
                    inputDisabled = true;
                    inputValue = '';
                }

                filtersHtml += `
                    <div class="col-12">
                        <div class="card border" style="background-color: var(--color-gray-100);">
                            <div class="card-body p-3">
                                <div class="row g-3 align-items-end">
                                    <div class="col-12 col-md-4">
                                        <label for="filter-attribute-${index}" class="form-label fw-semibold" style="font-size: 0.875rem;">Attribute</label>
                                        <select class="form-select" id="filter-attribute-${index}" aria-label="Select attribute">
                                            ${attributes.map(attr => `<option value="${attr.id}" ${filter.attributeId === attr.id ? 'selected' : ''}>${escapeHtml(attr.name)}</option>`).join('')}
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <label for="filter-operator-${index}" class="form-label fw-semibold" style="font-size: 0.875rem;">Operator</label>
                                        <select class="form-select" id="filter-operator-${index}" aria-label="Select operator">
                                            ${operators.map(op => `<option value="${op.value}" ${filter.operator === op.value ? 'selected' : ''}>${op.symbol} ${escapeHtml(op.name)}</option>`).join('')}
                                        </select>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <label for="filter-value-${index}" class="form-label fw-semibold" style="font-size: 0.875rem;">Value</label>
                                        <input type="${inputType}" ${inputStep ? `step="${inputStep}"` : ''}
                                               class="form-control" id="filter-value-${index}"
                                               value="${escapeHtml(inputValue)}"
                                               placeholder="${inputPlaceholder}"
                                               ${inputDisabled ? 'disabled' : ''}
                                               data-attr-type="${selectedAttr.attributeTypeID}"
                                               aria-label="Filter value">
                                    </div>
                                    <div class="col-12 col-md-1 d-flex justify-content-end">
                                        <button class="btn btn-outline-danger btn-sm" onclick="removeFilter(${index})"
                                                aria-label="Remove this filter" title="Remove filter">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>`;
            });

            filtersHtml += '</div>';
            container.innerHTML = filtersHtml;

            // Add change event listeners
            filters.forEach((filter, index) => {
                const attributeSelect = document.getElementById(`filter-attribute-${index}`);
                const operatorSelect = document.getElementById(`filter-operator-${index}`);
                const valueInput = document.getElementById(`filter-value-${index}`);

                attributeSelect.addEventListener('change', (e) => {
                    updateFilterAttribute(index, parseInt(e.target.value));
                });

                operatorSelect.addEventListener('change', (e) => {
                    updateFilterOperator(index, e.target.value);
                });

                // Apply datetime mask if applicable
                if (valueInput.dataset.attrType === 'datetime') {
                    applyDateTimeMask(valueInput);
                }

                valueInput.addEventListener('input', (e) => {
                    updateFilterValue(index, e.target.value);
                });
            });
        }

        function addFilter() {
            if (attributes.length === 0) {
                showError('No attributes available to filter on.');
                return;
            }

            filters.push({
                attributeId: attributes[0].id,
                operator: '=',
                value: ''
            });

            renderFilters();
        }

        function removeFilter(index) {
            filters.splice(index, 1);
            renderFilters();
        }

        function clearFilters() {
            filters = [];
            renderFilters();
        }

        async function search(loadMore = false) {
            if (isLoading) return;

            isLoading = true;
            const searchBtn = document.getElementById('search-btn');
            const loadMoreBtn = document.getElementById('load-more-btn');

            if (!loadMore) {
                hideError(); // Hide error when starting a new search
                searchBtn.disabled = true;
                searchBtn.textContent = 'Searching...';
                logs = [];
                nextLastId = null;

                // Show loading skeleton
                const container = document.getElementById('results-container');
                container.innerHTML = `
                    <div class="table-responsive">
                        <table class="table">
                            <tbody>
                                <tr class="skeleton-row"><td colspan="5"></td></tr>
                                <tr class="skeleton-row"><td colspan="5"></td></tr>
                                <tr class="skeleton-row"><td colspan="5"></td></tr>
                                <tr class="skeleton-row"><td colspan="5"></td></tr>
                                <tr class="skeleton-row"><td colspan="5"></td></tr>
                            </tbody>
                        </table>
                    </div>`;
            } else {
                loadMoreBtn.disabled = true;
                loadMoreBtn.textContent = 'Loading...';
            }

            try {
                // Collect filter values from filters array
                const requestFilters = [];
                for (let i = 0; i < filters.length; i++) {
                    const filter = filters[i];
                    const attributeId = filter.attributeId;
                    const operator = filter.operator;
                    let value = filter.value;

                    // Skip null operators or convert value
                    if (operator !== 'ISNULL' && operator !== 'ISNOTNULL') {
                        if (!value && value !== 0 && value !== '0') {
                            showError(`Please provide a value for filter ${i + 1}`);
                            return;
                        }

                        const attribute = attributes.find(a => a.id === attributeId);
                        if (attribute.attributeTypeID === 'integer') {
                            value = parseInt(value);
                        } else if (attribute.attributeTypeID === 'decimal') {
                            value = parseFloat(value);
                        } else if (attribute.attributeTypeID === 'datetime') {
                            // Convert dd/MM/yyyy HH:mm to ISO format
                            const isoValue = dateTimeToISO(value);
                            if (!isoValue) {
                                showError(`Invalid date format for filter ${i + 1}. Expected format: dd/MM/yyyy HH:mm`);
                                return;
                            }
                            value = isoValue;
                        }
                    } else {
                        value = null;
                    }

                    requestFilters.push({
                        logAttributeID: attributeId,
                        operator: operator,
                        value: value
                    });
                }

                const requestBody = {
                    lastId: loadMore ? nextLastId : null,
                    limit: 100,
                    filters: requestFilters
                };

                const response = await fetch(`/api/log-collections/${logCollectionId}/logs/search`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.detail || response.statusText);
                }

                const data = await response.json();

                if (loadMore) {
                    logs = logs.concat(data.logs);
                } else {
                    logs = data.logs;
                }

                nextLastId = data.nextLastId;

                renderResults(data.attributes);

            } catch (error) {
                console.error('Error searching logs:', error);
                showError('Failed to search logs: ' + error.message);
            } finally {
                isLoading = false;
                searchBtn.disabled = false;
                searchBtn.textContent = 'Search';
                loadMoreBtn.disabled = false;
                loadMoreBtn.textContent = 'Load More';
            }
        }

        function initializeColumnVisibility(attributesList) {
            // Initialize all columns as visible
            visibleColumns = { id: true, actions: true };
            attributesList.forEach(attr => {
                visibleColumns[attr.sqlColumnName] = true;
            });
        }

        function toggleColumnVisibility() {
            // Create a modal-like dropdown for column selection
            const existingModal = document.getElementById('column-toggle-modal');
            if (existingModal) {
                existingModal.remove();
                return;
            }

            const modal = document.createElement('div');
            modal.id = 'column-toggle-modal';
            modal.style.cssText = 'position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; border: 1px solid var(--color-border); border-radius: var(--border-radius-lg); box-shadow: var(--shadow-xl); padding: 1.5rem; z-index: 1050; max-width: 400px; width: 90%;';

            let modalHtml = '<h3 class="h5 mb-3">Show/Hide Columns</h3><div class="d-flex flex-column gap-2">';

            // ID column (always visible)
            modalHtml += '<div class="form-check"><input class="form-check-input" type="checkbox" id="col-toggle-id" checked disabled><label class="form-check-label" for="col-toggle-id">ID (always visible)</label></div>';

            // Attribute columns
            const attributesList = attributes;
            attributesList.forEach(attr => {
                const isChecked = visibleColumns[attr.sqlColumnName] ? 'checked' : '';
                modalHtml += `<div class="form-check"><input class="form-check-input" type="checkbox" id="col-toggle-${attr.sqlColumnName}" data-column="${attr.sqlColumnName}" ${isChecked}><label class="form-check-label" for="col-toggle-${attr.sqlColumnName}">${escapeHtml(attr.name)}</label></div>`;
            });

            // Actions column (always visible)
            modalHtml += '<div class="form-check"><input class="form-check-input" type="checkbox" id="col-toggle-actions" checked disabled><label class="form-check-label" for="col-toggle-actions">Actions (always visible)</label></div>';

            modalHtml += '</div><div class="mt-3 d-flex justify-content-end gap-2"><button class="btn btn-sm btn-outline-secondary" onclick="closeColumnToggle()">Close</button></div>';

            modal.innerHTML = modalHtml;
            document.body.appendChild(modal);

            // Add backdrop
            const backdrop = document.createElement('div');
            backdrop.id = 'column-toggle-backdrop';
            backdrop.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1040;';
            backdrop.onclick = closeColumnToggle;
            document.body.appendChild(backdrop);

            // Add event listeners to checkboxes
            attributesList.forEach(attr => {
                const checkbox = document.getElementById(`col-toggle-${attr.sqlColumnName}`);
                if (checkbox) {
                    checkbox.addEventListener('change', (e) => {
                        visibleColumns[attr.sqlColumnName] = e.target.checked;
                        renderResults(attributesList);
                    });
                }
            });
        }

        function closeColumnToggle() {
            const modal = document.getElementById('column-toggle-modal');
            const backdrop = document.getElementById('column-toggle-backdrop');
            if (modal) modal.remove();
            if (backdrop) backdrop.remove();
        }

        function renderResults(attributesList) {
            const container = document.getElementById('results-container');
            const loadMoreContainer = document.getElementById('load-more-container');
            const resultsCount = document.getElementById('results-count');
            const columnToggleBtn = document.getElementById('column-toggle-btn');

            if (logs.length === 0) {
                container.innerHTML = `
                    <div class="table-empty">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="table-empty-icon" viewBox="0 0 16 16" aria-hidden="true">
                            <path d="M8.5 2.687c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/>
                        </svg>
                        <div class="table-empty-message">No results found</div>
                        <div class="table-empty-description">
                            <p class="mb-2">Your search didn't return any results.</p>
                            <small class="text-muted">
                                <strong>Suggestions:</strong><br>
                                • Check your filter values for typos<br>
                                • Try using different operators (e.g., "Contains" instead of "Equal")<br>
                                • Remove some filters to broaden your search<br>
                                • Verify the date/time format is correct (dd/MM/yyyy HH:mm)
                            </small>
                        </div>
                    </div>`;
                loadMoreContainer.style.display = 'none';
                resultsCount.style.display = 'none';
                columnToggleBtn.style.display = 'none';
                return;
            }

            // Initialize column visibility if not already done
            if (Object.keys(visibleColumns).length === 0) {
                initializeColumnVisibility(attributesList);
            }

            // Update results count badge
            const countText = logs.length === 1 ? '1 record' : `${logs.length} records`;
            resultsCount.textContent = nextLastId ? `${countText} (more available)` : countText;
            resultsCount.style.display = 'inline-block';
            columnToggleBtn.style.display = 'inline-block';

            // Build table with sticky header wrapper
            let tableHtml = '<div class="table-responsive table-sticky-header" style="max-height: 600px;">';
            tableHtml += '<table class="table table-hover table-sm">';
            tableHtml += '<thead><tr>';
            tableHtml += '<th class="col-id">ID</th>';

            // Add attribute columns (only visible ones)
            attributesList.forEach(attr => {
                if (!visibleColumns[attr.sqlColumnName]) return;

                let colClass = '';
                if (attr.attributeTypeID === 'datetime') {
                    colClass = 'col-datetime';
                } else if (attr.attributeTypeID === 'integer' || attr.attributeTypeID === 'decimal') {
                    colClass = 'col-numeric';
                }
                tableHtml += `<th class="${colClass}">${escapeHtml(attr.name)}</th>`;
            });
            tableHtml += '<th class="col-actions-sm">Actions</th>';

            tableHtml += '</tr></thead><tbody>';

            logs.forEach(log => {
                tableHtml += '<tr>';
                tableHtml += `<td class="col-id">${log.id}</td>`;

                attributesList.forEach(attr => {
                    if (!visibleColumns[attr.sqlColumnName]) return;

                    const value = log.attributes[attr.sqlColumnName];
                    let cellClass = '';

                    if (attr.attributeTypeID === 'datetime') {
                        cellClass = 'col-datetime';
                    } else if (attr.attributeTypeID === 'integer' || attr.attributeTypeID === 'decimal') {
                        cellClass = 'col-numeric';
                    }

                    if (value === null || value === undefined) {
                        tableHtml += `<td class="${cellClass} text-muted"><em>null</em></td>`;
                    } else if (attr.attributeTypeID === 'datetime') {
                        tableHtml += `<td class="${cellClass} col-nowrap">${escapeHtml(formatDateTime(value))}</td>`;
                    } else if (typeof value === 'boolean') {
                        const badgeClass = value ? 'bg-success' : 'bg-secondary';
                        tableHtml += `<td class="${cellClass}"><span class="badge ${badgeClass}">${value ? 'true' : 'false'}</span></td>`;
                    } else {
                        tableHtml += `<td class="${cellClass}">${escapeHtml(String(value))}</td>`;
                    }
                });

                // Add download button
                const downloadUrl = `/api/log-collections/${logCollectionId}/logs/${log.id}/download`;
                tableHtml += `<td class="col-actions-sm"><a href="${downloadUrl}" class="btn btn-sm btn-primary" target="_blank" title="Download log">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                        <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                    </svg>
                    <span class="d-none d-lg-inline ms-1">Download</span>
                </a></td>`;

                tableHtml += '</tr>';
            });

            tableHtml += '</tbody></table></div>';

            container.innerHTML = tableHtml;

            // Show/hide load more button
            if (nextLastId) {
                loadMoreContainer.style.display = 'block';
            } else {
                loadMoreContainer.style.display = 'none';
            }
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            const errorText = document.getElementById('error-message-text');
            errorText.textContent = message;
            errorDiv.style.display = 'flex';

            document.getElementById('success-message').style.display = 'none';
        }

        function hideError() {
            const errorDiv = document.getElementById('error-message');
            errorDiv.style.display = 'none';
        }

        function showSuccess(message) {
            const successDiv = document.getElementById('success-message');
            const successText = document.getElementById('success-message-text');
            successText.textContent = message;
            successDiv.style.display = 'flex';

            document.getElementById('error-message').style.display = 'none';

            setTimeout(() => {
                dismissAlert(successDiv);
            }, 3000);
        }

        function escapeHtml(text) {
            if (text === null || text === undefined) return '';
            const div = document.createElement('div');
            div.textContent = String(text);
            return div.innerHTML;
        }

        // Wire up event handlers
        document.getElementById('add-filter-btn').addEventListener('click', addFilter);
        document.getElementById('search-btn').addEventListener('click', () => search(false));
        document.getElementById('clear-filters-btn').addEventListener('click', clearFilters);
        document.getElementById('clear-all-pills-btn').addEventListener('click', clearFilters);
        document.getElementById('load-more-btn').addEventListener('click', () => search(true));
        document.getElementById('column-toggle-btn').addEventListener('click', toggleColumnVisibility);

        // Mobile filter toggle
        const toggleFiltersBtn = document.getElementById('toggle-filters-btn');
        const filtersBody = document.getElementById('filters-body');
        const toggleFiltersIcon = document.getElementById('toggle-filters-icon');

        if (toggleFiltersBtn) {
            toggleFiltersBtn.addEventListener('click', () => {
                const isExpanded = toggleFiltersBtn.getAttribute('aria-expanded') === 'true';
                toggleFiltersBtn.setAttribute('aria-expanded', !isExpanded);
                filtersBody.style.display = isExpanded ? 'none' : 'block';
                toggleFiltersIcon.textContent = isExpanded ? '+' : '−';
            });
        }
    </script>
}
