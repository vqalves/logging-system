@*
    Reusable Empty State Component

    Usage:
    @{
        ViewData["EmptyStateId"] = "my-empty-state"; // optional
        ViewData["EmptyStateTitle"] = "No items found";
        ViewData["EmptyStateMessage"] = "Get started by creating a new item"; // optional
        ViewData["EmptyStateActionText"] = "Create New Item"; // optional
        ViewData["EmptyStateActionUrl"] = "/create"; // optional
        ViewData["EmptyStateVisible"] = true; // optional, default true
    }
    @await Html.PartialAsync("_Components/_EmptyState")
*@

@{
    var emptyStateId = ViewData["EmptyStateId"]?.ToString() ?? "empty-state";
    var emptyStateTitle = ViewData["EmptyStateTitle"]?.ToString() ?? "No items found";
    var emptyStateMessage = ViewData["EmptyStateMessage"]?.ToString();
    var actionText = ViewData["EmptyStateActionText"]?.ToString();
    var actionUrl = ViewData["EmptyStateActionUrl"]?.ToString();
    var visible = ViewData["EmptyStateVisible"] as bool? ?? true;
    var displayStyle = visible ? "" : "display: none;";
}

<div id="@emptyStateId" class="empty-state text-center py-5" style="@displayStyle">
    <div class="empty-state-icon mb-3" aria-hidden="true">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="9" y1="9" x2="15" y2="15"></line>
            <line x1="15" y1="9" x2="9" y2="15"></line>
        </svg>
    </div>
    <h3 class="h5 text-muted mb-2">@emptyStateTitle</h3>
    @if (!string.IsNullOrEmpty(emptyStateMessage))
    {
        <p class="text-muted mb-3">@emptyStateMessage</p>
    }
    @if (!string.IsNullOrEmpty(actionText) && !string.IsNullOrEmpty(actionUrl))
    {
        <a href="@actionUrl" class="btn btn-primary">@actionText</a>
    }
</div>
